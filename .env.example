# Environment variables for Tavera
# Copy to .env and fill in values. Never commit .env.

# Database
DATABASE_URL=postgresql://user:password@host:5432/tavera

# BC Government APIs
ORGBOOK_BC_API_URL=https://orgbook.gov.bc.ca/api/v4
FRASER_HEALTH_API_URL=<fraser_health_endpoint>
VCH_API_URL=<vch_endpoint>

# Webhooks
WEBHOOK_SIGNING_SECRET=<generate_random_secret>

# Optional: Sentry DSN for error tracking
SENTRY_DSN=
